          {%- assign stockStatusSub = "Estimated Ship Date 5 – 6 mths" -%}
        {%- elsif leadTime < 211 -%}
          {%- assign stockStatusSub = "Estimated Ship Date 6 – 7 mths" -%}
        {%- elsif leadTime < 1000 -%}
          {%- assign stockStatusSub = "Estimated Ship Date over 7 mths" -%}
        {%- endif %}
