{% doc %}
@prompt
Create me a block that takes up 320px height and full screen (1400px) width. The left 2/3 should have a heading and text. the right 1/3should have an updateable image, Should have a background that can be uploaded.. This needs to be responsive
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}

  .ai-split-content-{{ ai_gen_id }} {
  display: block;
  position: relative;
  width: 100%;
  max-width: 1400px;
  height: 300px;
  margin: 0 auto;
  overflow: hidden;
  }

  .ai-split-content-contain-{{ ai_gen_id }}{
    margin:15px auto;
    position:relative;
  }


  .ai-split-content-background-{{ ai_gen_id }} {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 175px;
  margin-top:40px;
  z-index: 1;
  }

  .ai-split-content-background-{{ ai_gen_id }} img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  }

  .ai-split-content-background-placeholder-{{ ai_gen_id }} {
  width: 100%;
  height: 100%;
  background-color: {{ block.settings.fallback_background_color }};
  }

  .ai-split-content-background-placeholder-{{ ai_gen_id }} svg {
  width: 100%;
  height: 100%;
  opacity: 0.1;
  }

  .ai-split-content-wrapper-{{ ai_gen_id }} {
  position: relative;
  z-index: 2;
  display: flex;
  height: 100%;
  width: 100%;
  }

  .ai-split-content-left-{{ ai_gen_id }} {
  width: 62.666%;
  {% comment %}padding: {{ block.settings.content_padding }}px;{% endcomment %}
  padding: 10px 45px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16px;
  }

  .ai-split-content-heading-{{ ai_gen_id }},
  .ai-split-content-heading-{{ ai_gen_id }} p {
  margin: 0 0 -5px 0;
  font-size: {{ block.settings.heading_size }}px;
  color: {{ block.settings.heading_color }};
  line-height: 1.2;
  }

  .ai-split-content-text-{{ ai_gen_id }},
  .ai-split-content-text-{{ ai_gen_id }} p{
  margin: 0;
  padding:0;
  font-size: {{ block.settings.text_size }}px;
  color: {{ block.settings.text_color }};
  line-height: 1.3;
  max-width:572px;
  }

  .ai-split-content-right-{{ ai_gen_id }} {
  width: 33.333%;
  position: relative;
  overflow: hidden;
  }
  .ai-split-content-right-{{ ai_gen_id }} .img-contain {
  max-width:300px;
  max-height:300px;
  margin:auto;
  }

  .ai-split-content-right-{{ ai_gen_id }} img {

  }

  .ai-split-content-image-placeholder-{{ ai_gen_id }} {
  width: 100%;
  height: 100%;
  background-color: #f4f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  }

  .ai-split-content-image-placeholder-{{ ai_gen_id }} svg {
  width: 60%;
  height: 60%;
  opacity: 0.3;
  }

  @media screen and (max-width: 1279px) {
    .ai-split-content-heading-{{ ai_gen_id }},
    .ai-split-content-heading-{{ ai_gen_id }} p {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
    .ai-split-content-text-{{ ai_gen_id }},
    .ai-split-content-text-{{ ai_gen_id }} p{
        font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
    .ai-split-content-right-{{ ai_gen_id }} .img-contain {
      max-width:250px;
      max-height:250px;
      margin:35px auto 0 auto;
    }

  }

  @media screen and (max-width: 768px) {
  .ai-split-content-background-{{ ai_gen_id }} {
  margin-top:10px;
  }

  .ai-split-content-right-{{ ai_gen_id }} .img-contain {
  margin:-20px auto 0 auto;
  }


  .ai-split-content-{{ ai_gen_id }} {
  height: auto;
  min-height:unset;
  margin-bottom:30px
  }

  .ai-split-content-wrapper-{{ ai_gen_id }} {
  flex-direction: column;
  }

  .ai-split-content-left-{{ ai_gen_id }} {
  width: 100%;
  padding: 0 15px 20px 15px;
  min-height: unset;
  text-align:center;
  order:2;
  }

  .ai-split-content-right-{{ ai_gen_id }} {
  width: 100%;
  min-height: 200px;
  order:1;
  }

  .ai-split-content-text-{{ ai_gen_id }},
  .ai-split-content-text-{{ ai_gen_id }} p{
  text-align:center;
  max-width: unset;
  color: {{ block.settings.heading_color }};
  }


  }
{% endstyle %}

<split-content-{{ ai_gen_id }} class="ai-split-content-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-content-contain-{{ ai_gen_id }}">
    <div class="ai-split-content-background-{{ ai_gen_id }}">
      {% if block.settings.background_image %}
        <img
                src="{{ block.settings.background_image | image_url: width: 1400 }}"
                alt="{{ block.settings.background_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.background_image.width }}"
                height="{{ block.settings.background_image.height }}"
        >
      {% else %}
        <div class="ai-split-content-background-placeholder-{{ ai_gen_id }}">
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-split-content-wrapper-{{ ai_gen_id }}">
      <div class="ai-split-content-left-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-split-content-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.text != blank %}
          <div class="ai-split-content-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% endif %}
      </div>

      <div class="ai-split-content-right-{{ ai_gen_id }}">
        <div class="img-contain">
          {% if block.settings.right_image %}
            <img
                    class="img-responsive"
                    src="{{ block.settings.right_image | image_url: width: 600 }}"
                    alt="{{ block.settings.right_image.alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings.right_image.width }}"
                    height="{{ block.settings.right_image.height }}"
            >
          {% else %}
            <div class="ai-split-content-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</split-content-{{ ai_gen_id }}>

<script>
  (function() {
    class SplitContent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustHeight();
        window.addEventListener('resize', () => this.adjustHeight());
      }

      adjustHeight() {
        if (window.innerWidth <= 768) {
          const leftSection = this.querySelector('.ai-split-content-left-{{ ai_gen_id }}');
          const rightSection = this.querySelector('.ai-split-content-right-{{ ai_gen_id }}');
          if (leftSection && rightSection) {
            const totalHeight = leftSection.offsetHeight + rightSection.offsetHeight;
            this.style.height = totalHeight + 'px';
          }
        } else {
          this.style.height = '280px';
        }
      }
    }

    customElements.define('split-content-{{ ai_gen_id }}', SplitContent{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Split content block",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "fallback_background_color",
      "label": "Fallback background color",
      "default": "#f4f4f4"
    },
    {
      "type": "header",
      "content": "Left content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Your heading here</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add your descriptive text content here. This section takes up two-thirds of the block width on desktop.</p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#303e48"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#303e48"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Right image"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "mobile_content_padding",
      "label": "Mobile padding",
      "min": 15,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Split content block"
    }
  ]
}
{% endschema %}
